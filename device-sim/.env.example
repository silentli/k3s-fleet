# MQTT Broker Settings
# If testing locally on the same machine
MQTT_BROKER_PORT=1883
MQTT_TOPIC=factory/telemetry

# File Paths
FACTORY_LAYOUT_FILE=layout.json

# Factory Layout Settings
FACTORY_MAX_X=100
FACTORY_MAX_Y=100

# Robot Physical Parameters
ROBOT_SPEED_MPS=1.5
BATTERY_CHARGE_RATE=8.0
BATTERY_DRAIN_MOVING=0.2
BATTERY_DRAIN_IDLE=0.1
BATTERY_LOW_THRESHOLD=20.0